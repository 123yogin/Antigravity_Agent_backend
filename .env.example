# Antigravity Operator — Environment Configuration
# Copy this to .env and customize

# ─── Ollama Models ───────────────────────────────────────────────────────────
CODER_MODEL=qwen2.5-coder:latest
ROUTER_MODEL=llama3.2:latest
EMBED_MODEL=nomic-embed-text

# ─── Ollama Connection ──────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434

# ─── Execution Limits ────────────────────────────────────────────────────────
MAX_RETRIES=3
COMMAND_TIMEOUT=60
MAX_PLAN_STEPS=15
AUTONOMOUS_LOOP_LIMIT=50

# ─── API ─────────────────────────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8000

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
